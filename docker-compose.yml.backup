# Feito com Muito S2 e Muito Café :)

services:
  # =========================
  # BANCO DE DADOS POSTGRES
  # =========================
  db:
    container_name: paybank-db
    image: postgres:13
    environment:
      POSTGRES_USER: dba
      POSTGRES_PASSWORD: dba
      POSTGRES_DB: UserDB
    ports:
      - "5433:5432"
    restart: always
    networks:
      - skynet

    volumes:
      - pgdata:/var/lib/postgresql/data

    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U dba -d UserDB" ]
      interval: 5s
      timeout: 5s
      retries: 10

  # =========================
  # PGADMIN
  # =========================
  pgadmin:
    container_name: paybank-dbadm
    image: dpage/pgadmin4
    environment:
      PGADMIN_DEFAULT_EMAIL: dba@pgadmin.com
      PGADMIN_DEFAULT_PASSWORD: dba
      TZ: America/Sao_Paulo
    ports:
      - "15432:80"
    depends_on:
      - db
    restart: always
    networks:
      - skynet

  # =========================
  # REDIS
  # =========================
  redis:
    container_name: paybank-redis
    image: redis:6.2
    environment:
      TZ: America/Sao_Paulo
    ports:
      - "6379:6379"
    restart: always
    networks:
      - skynet

  # =========================
  # REDIS INSIGHT
  # =========================
  redis-insight:
    container_name: paybank-redisadm
    image: redislabs/redisinsight:latest
    environment:
      TZ: America/Sao_Paulo
    ports:
      - "5540:5540"
    depends_on:
      - redis
    restart: always
    networks:
      - skynet

  # =========================
  # MS AUTH
  # =========================
  paybank-ms-auth:
    platform: linux/amd64
    container_name: paybank-ms-auth
    image: papitodev/paybank-ms-auth
    networks:
      - skynet

    depends_on:
      db:
        condition: service_healthy

    environment:
      DATABASE_URL: postgresql://dba:dba@paybank-db:5432/UserDB
      REDIS_HOST: paybank-redis
      REDIS_PORT: 6379
      TZ: America/Sao_Paulo

    ports:
      - "3333:3333"
    restart: unless-stopped

  # =========================
  # MS EMAIL
  # =========================
  paybank-ms-email:
    platform: linux/amd64
    container_name: paybank-ms-email
    image: papitodev/paybank-ms-email
    networks:
      - skynet

    depends_on:
      - paybank-ms-auth

    environment:
      REDIS_HOST: paybank-redis
      REDIS_PORT: 6379
      MAILTRAP_ACCOUNT_ID: 4612351
      MAILTRAP_TOKEN: 0e5d19ad4f244eca9e64c10bb644120a
      MAILTRAP_INBOX_ID: 4612351
      TZ: America/Sao_Paulo

    restart: unless-stopped

  # =========================
  # FRONTEND AUTH
  # =========================
  paybank-mf-auth:
    platform: linux/amd64
    container_name: paybank-mf-auth
    image: papitodev/paybank-mf-auth
    networks:
      - skynet

    depends_on:
      - paybank-ms-auth

    environment:
      TZ: America/Sao_Paulo

    ports:
      - "3000:3000"
    restart: unless-stopped
    # Serviço de Jenkins para integração contínua
  jenkins:
    image: jenkins/jenkins:lts # Usar imagem pronta em vez de build
    container_name: jenkins-server
    privileged: true
    user: root
    networks:
      - skynet
    restart: always
    environment:
      - TZ=America/Sao_Paulo
    ports:
      - "8080:8080"
      - "50000:50000"
    volumes:
      - jenkins_home:/var/jenkins_home
      - /var/run/docker.sock:/var/run/docker.sock
# =========================
# NETWORKS
# =========================
networks:
  skynet:
    driver: bridge

# =========================
# VOLUMES
# =========================
volumes:
  jenkins_home:
  pgdata:
